# LearnIQ Backend API Configuration
# Copy this file to .env and update with your values

# ============================================
# BACKEND API CONFIGURATION
# ============================================

# Localhost Development Setup
# If running backend on localhost:5000 and frontend on localhost:3000+
VITE_API_URL=http://localhost:5000/api/v1
REACT_APP_API_URL=http://localhost:5000/api/v1

# Netlify + External Backend Setup
# Uncomment below and update with your production backend URL
# VITE_API_URL=https://your-backend-api.com/api/v1
# REACT_APP_API_URL=https://your-backend-api.com/api/v1

# Local Network IP Setup
# For mobile testing on local network (e.g., 192.168.1.x)
# VITE_API_URL=http://192.168.1.100:5000/api/v1
# REACT_APP_API_URL=http://192.168.1.100:5000/api/v1

# Docker Setup
# If backend is running in Docker on localhost
# VITE_API_URL=http://localhost:8000/api/v1
# REACT_APP_API_URL=http://localhost:8000/api/v1

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Node environment
NODE_ENV=development

# Frontend port (for local development)
VITE_PORT=3000

# Enable debug logging
VITE_DEBUG=true

# ============================================
# PWA CONFIGURATION
# ============================================

# Service Worker enabled
VITE_SERVICE_WORKER_ENABLED=true

# Offline mode support
VITE_OFFLINE_MODE=true

# ============================================
# DEPLOYMENT CONFIGURATION
# ============================================

# Netlify site name (for Netlify CLI)
# NETLIFY_SITE_NAME=your-site-name

# Netlify build context
CONTEXT=production
