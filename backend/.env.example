# ==================== PRODUCTION CONFIGURATION ====================
# This is an example configuration file. Copy this to .env and update with your values.
# NEVER commit the actual .env file to version control.

# ==================== SERVER CONFIGURATION ====================
PORT=5000
NODE_ENV=production

# ==================== DATABASE CONFIGURATION ====================
# Update these with your actual database credentials
DB_HOST=your-db-host.com
DB_USER=your-db-user
DB_PASSWORD=your-secure-password-here
DB_NAME=pwa_let_db
DB_PORT=3306

# ==================== JWT CONFIGURATION ====================
# Generate a strong secret key for production
JWT_SECRET=your-strong-jwt-secret-key-change-in-production
JWT_EXPIRATION=7d

# ==================== FILE UPLOAD ====================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ==================== CORS CONFIGURATION ====================
# For production, specify your exact domain(s)
# Examples:
#   Single domain: https://yourapp.com
#   Multiple domains: https://yourapp.com,https://app.yourapp.com
#   Development: http://localhost:3000
CORS_ORIGIN=https://yourapp.com

# ==================== API CONFIGURATION ====================
# This is the URL where your backend is accessible from the frontend
# For same-domain deployment: /api/v1
# For separate subdomains: https://api.yourapp.com/api/v1
API_URL=https://yourapp.com/api/v1
API_PREFIX=/api/v1

# ==================== OPTIONAL: ADDITIONAL SETTINGS ====================
# Add any other environment variables your application needs
# LOG_LEVEL=info
# SESSION_SECRET=your-session-secret
